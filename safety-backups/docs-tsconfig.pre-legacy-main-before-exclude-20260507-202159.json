{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@noctra/react": [
        "src/components/docs-system/NoctraRuntimeMock.tsx"
      ],
      "@noctra/react/*": [
        "src/components/docs-system/NoctraRuntimeMock.tsx"
      ],
      "@noctra/tokens": [
