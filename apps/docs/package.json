{
  "name": "@noctra/docs",
  "version": "0.0.0",
  "private": true,
  "description": "Noctra documentation app.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "Remove-Item -Recurse -Force dist -ErrorAction SilentlyContinue"
  },
  "dependencies": {
    "@noctra/react": "workspace:*",
    "@noctra/styles": "workspace:*",
    "@noctra/tokens": "workspace:*",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2"
  },
  "license": "MIT"
}
