{
    "name":  "@noctra/tokens",
    "version":  "0.0.0-alpha.0",
    "private":  false,
    "description":  "Token names and metadata for the Noctra design ecosystem.",
    "license":  "MIT",
    "type":  "module",
    "main":  "./dist/index.js",
    "types":  "./dist/index.d.ts",
    "files":  [
                  "dist",
                  "README.md",
                  "LICENSE"
              ],
    "keywords":  [
                     "tokens",
                     "design-tokens",
                     "metadata",
                     "theme",
                     "design-system",
                     "noctra"
                 ],
    "exports":  {
                    ".":  {
                              "types":  "./dist/index.d.ts",
                              "import":  "./dist/index.js"
                          }
                },
    "sideEffects":  false,
    "publishConfig":  {
                          "access":  "public"
                      },
    "scripts":  {
                    "build":  "tsc -p tsconfig.json",
                    "typecheck":  "tsc --noEmit -p tsconfig.json",
                    "clean":  "Remove-Item -Recurse -Force dist -ErrorAction SilentlyContinue"
                }
}
